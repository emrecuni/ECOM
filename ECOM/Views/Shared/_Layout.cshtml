<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-COM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        bool isLoginPage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Login";
        bool isAccountPage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Account";
        bool isCartPage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Cart";
        bool isPaymentPage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Payment";
    }

    @if (!isLoginPage && !isPaymentPage)
    {
        @await Html.PartialAsync("_Header")
    }

    <main class="@(isLoginPage || isPaymentPage ? "" : "py-2")">
        @RenderBody()
    </main>

    @if (!isLoginPage && !isPaymentPage)
    {
        @await Html.PartialAsync("_Footer")
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
