@model IEnumerable<ECOM.MVC.OldFiles.DTO.ProductDTO>

@section Styles {
    <link rel="stylesheet" href="~/css/main.css">
}

<div class="container page-section">
    <div class="section-header">
        <h2 class="section-title">Tüm Ürünler</h2>
        <span style="font-size:13px; color:var(--text-muted);">@(Model?.Count() ?? 0) ürün listeleniyor</span>
    </div>

    @if (Model is not null && Model.Any())
    {
        <div class="products-grid">
            @foreach (var product in Model)
            {
                @await Html.PartialAsync("Product", product)
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-box-open" style="font-size:48px; color:var(--gray-300); display:block; margin-bottom:16px;"></i>
            <h4>Ürün bulunamadı</h4>
            <p>Aradığınız kriterlere uygun ürün henüz eklenmemiş.</p>
        </div>
    }
</div>

<script src="~/js/favorite.js"></script>
