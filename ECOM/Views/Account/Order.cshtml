@model IEnumerable<ECOM.Data.OrderHistory>?

<!-- Filters -->
<div style="display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap;">
    <div style="position:relative; flex:1; min-width:200px;">
        <i class="fas fa-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--gray-400); font-size:13px;"></i>
        <input type="text" class="form-control" placeholder="Siparişlerimde ara..." style="padding-left:38px;" id="orderSearch">
    </div>

    <div style="display:flex; gap:6px; flex-wrap:wrap;">
        <button class="order-filter-btn active" data-filter="all">Tümü</button>
        <button class="order-filter-btn" data-filter="active">Devam Edenler</button>
        <button class="order-filter-btn" data-filter="delivered">Teslim Edildi</button>
        <button class="order-filter-btn" data-filter="cancelled">İptaller</button>
    </div>

    <select class="order-period-select">
        <option value="0">Tüm Siparişler</option>
        <option value="30">Son 30 Gün</option>
        <option value="180">Son 6 Ay</option>
        <option value="365">Son 1 Yıl</option>
        <option value="999">1 Yıl Önce</option>
    </select>
</div>

<!-- Order List -->
@if (Model is null || !Model.Any())
{
    <div style="text-align:center; padding:48px 24px; color:var(--text-muted);">
        <i class="fas fa-box-open" style="font-size:40px; color:var(--gray-300); display:block; margin-bottom:16px;"></i>
        <p style="font-size:15px; font-weight:600; color:var(--text-secondary); margin-bottom:6px;">Henüz siparişiniz yok</p>
        <p style="font-size:13.5px;">İlk alışverişinizi yapmak için <a asp-controller="Main" asp-action="Index" style="color:var(--primary); font-weight:600;">buraya tıklayın</a>.</p>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        string orderStatus = order.DeliveryDate is not null ? "Teslim Edildi" : "Sipariş Hazırlanıyor";
        string statusClass = order.DeliveryDate is not null ? "status-delivered" : "status-processing";
        string statusIcon = order.DeliveryDate is not null ? "fas fa-check-circle" : "fas fa-clock";

        <div class="order-history-card">
            <div class="order-history-card-header">
                <div style="display:flex; align-items:center; gap:10px;">
                    <img src="~/@order.Product.ImagePath" class="order-thumb" alt="Ürün" />
                    <div>
                        <div style="font-size:12px; color:var(--text-muted);">Sipariş No</div>
                        <div style="font-size:14px; font-weight:700; color:var(--text-primary);">#@order.OrderId</div>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
                    <div style="text-align:right;">
                        <div style="font-size:12px; color:var(--text-muted);">Tarih</div>
                        <div style="font-size:13.5px; font-weight:600;">@order.OrderDate!.Value.ToShortDateString()</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:12px; color:var(--text-muted);">Tutar</div>
                        <div style="font-size:16px; font-weight:700; color:var(--primary); font-family:var(--font-display);">₺@order.TotalPrice</div>
                    </div>
                    <span class="order-status-badge @statusClass">
                        <i class="@statusIcon"></i> @orderStatus
                    </span>
                </div>
            </div>
        </div>
    }
}
