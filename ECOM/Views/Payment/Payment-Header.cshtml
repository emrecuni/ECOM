<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="~/css/payment-header.css">

<div class="payment-header-bar">
    <div class="container">
        <div class="payment-header-inner">
            <!-- Logo -->
            <a asp-controller="Main" asp-action="Index" class="payment-logo">
                <span class="logo-text">e-com</span>
            </a>

            <!-- Secure Badge -->
            <div class="payment-secure-badge">
                <i class="fas fa-shield-alt"></i>
                Güvenli Alışveriş
            </div>

            <!-- Account -->
            <a asp-controller="Account" asp-action="Index" asp-route-id="user"
               style="width:38px; height:38px; border-radius:50%; background:var(--primary-bg); border:1.5px solid var(--primary); display:flex; align-items:center; justify-content:center; color:var(--primary); font-size:15px;">
                <i class="fas fa-user"></i>
            </a>
        </div>
    </div>
</div>
