@model ECOM.MVC.OldFiles.Data.Customers

<div class="membership-form">
    <p style="font-size:13.5px; color:var(--text-muted); margin-bottom:24px; display:flex; align-items:center; gap:8px;">
        <i class="fas fa-info-circle" style="color:var(--primary);"></i>
        E-posta adresinizi değiştirmek için doğrulama gereklidir.
    </p>

    <!-- Phone -->
    <form method="post" action="CommunicationSettings">
        <div class="form-field-group">
            <label class="field-label">Cep Telefonu</label>
            <div class="field-input-wrapper">
                <input type="tel" class="field-input" id="phone" name="phone"
                       value="@Model.Phone" placeholder="05XX XXX XX XX" required>
                <i class="fas fa-phone"></i>
            </div>
        </div>
        <button class="account-save-btn" type="submit">
            <i class="fas fa-check"></i> Telefonu Güncelle
        </button>
    </form>

    <!-- Email (readonly) -->
    <div style="margin-top:28px; padding-top:24px; border-top:1px solid var(--gray-200);">
        <div class="form-field-group">
            <label class="field-label">E-Posta Adresi</label>
            <div class="field-input-wrapper">
                <input type="email" class="field-input" value="@Model.Email" disabled
                       style="background:var(--gray-100); color:var(--text-muted); cursor:not-allowed;">
                <i class="fas fa-envelope"></i>
            </div>
        </div>
        <button type="button" class="account-outline-btn" id="btnOpenForm" data-email="@Model.Email">
            <i class="fas fa-pen"></i> E-Posta Adresini Değiştir
        </button>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $("#btnOpenForm").click(function () {
        const email = $(this).data("email");
        $.post("/Account/SendOTPCode", "toMail=" + email, function (data) {
            $("#myModal .modal-content").html(data);
            new bootstrap.Modal(document.getElementById('myModal')).show();
        });
    });

    $(document).on("submit", "#userForm", function (e) {
        e.preventDefault();
        const extra = "customerId=@Model.CustomerId&phone=@Model.Phone";
        $.post("/Account/EditCommunicationSettings", extra + "&" + $(this).serialize(), function () {});
    });
</script>
