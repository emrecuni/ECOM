@model ECOM.Models.CartViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css">
    <link rel="stylesheet" href="~/css/main.css">
}

<div class="container cart-page">
    <!-- Cart Header Steps -->
    <div class="cart-header-bar">
        <div class="cart-steps">
            <div class="cart-step active">
                <span class="cart-step-num">1</span>
                <span>Sepetim</span>
            </div>
            <div class="cart-step-line"></div>
            <div class="cart-step">
                <span class="cart-step-num">2</span>
                <span>Adres</span>
            </div>
            <div class="cart-step-line"></div>
            <div class="cart-step">
                <span class="cart-step-num">3</span>
                <span>Ödeme</span>
            </div>
        </div>
    </div>

    @if (Model.Carts is null || Model.Carts.Count == 0)
    {
        <!-- Empty Cart -->
        <div class="empty-cart-wrapper">
            <img src="~/img/cart.gif" alt="Boş Sepet">
            <h4>Sepetin şu an boş</h4>
            <p>Sepetini e-com'un fırsatlarla dolu dünyasından doldurmak için aşağıdaki ürünleri incelemeye başlayabilirsin.</p>
            <a asp-controller="Main" asp-action="Index" class="btn-primary-custom" style="margin-top:24px;">
                <i class="fas fa-arrow-left"></i> Alışverişe Devam Et
            </a>
        </div>

        @if (Model.Favorites is not null && Model.Favorites.Any())
        {
            <div class="suggestion-section">
                <h3 class="suggestion-title">
                    <i class="fas fa-heart" style="color:var(--danger); margin-right:8px;"></i>
                    Beğendiklerim
                </h3>
                <div class="products-grid">
                    @await Html.PartialAsync("Suggestion", Model.Favorites)
                </div>
            </div>
        }
    }
    else
    {
        <!-- Coupon Bar -->
        <div class="coupons-bar">
            <a asp-controller="Account" asp-action="Index" asp-route-id="coupon" class="coupon-link">
                <i class="fas fa-gift"></i>
                Kuponlarım
            </a>
            <a href="#" class="add-coupon-btn">
                Kupon Kodu Ekle <i class="fas fa-plus"></i>
            </a>
        </div>

        <!-- Cart Title -->
        <div class="cart-title">
            Sepetim
            <span class="cart-count-badge">@Model.Carts.Count Ürün</span>
        </div>

        <!-- Cart Layout -->
        <div class="cart-layout">
            <!-- Orders -->
            <div class="orders-col">
                @foreach (var cart in Model.Carts.ToList())
                {
                    @await Html.PartialAsync("Cart", cart)
                }
            </div>

            <!-- Cart Total -->
            @{
                decimal cartSummaryPrice = 0;
                int cartSummaryProductCount = 0;
                foreach (var cart in Model.Carts.ToList())
                {
                    if (cart.Enable == true)
                    {
                        cartSummaryPrice += cart.TotalPrice;
                        cartSummaryProductCount++;
                    }
                }
            }

            <div class="cart-total-panel">
                <div class="cart-total-title">
                    <i class="fas fa-receipt" style="color:var(--primary); margin-right:8px;"></i>
                    Sipariş Özeti
                </div>

                <div class="cart-total-row">
                    <span>Seçilen Ürünler (@cartSummaryProductCount)</span>
                    <span>₺@cartSummaryPrice.ToString("F2")</span>
                </div>
                <div class="cart-total-row">
                    <span>Kargo</span>
                    <span class="cargo-free"><i class="fas fa-check"></i> Bedava</span>
                </div>
                <div class="cart-total-row grand-total">
                    <span>Toplam</span>
                    <span class="amount">₺@cartSummaryPrice.ToString("F2")</span>
                </div>

                <form asp-controller="Payment" asp-action="Index" method="post">
                    <input type="hidden" name="cart-total" value="@cartSummaryPrice" />
                    <button type="submit" class="checkout-btn">
                        <i class="fas fa-lock"></i>
                        Alışverişi Tamamla
                    </button>
                </form>

                <div style="display:flex; align-items:center; gap:6px; color:var(--success); font-size:12.5px; font-weight:600; justify-content:center; margin-top:12px;">
                    <i class="fas fa-shield-alt"></i> 256-bit SSL ile güvenli ödeme
                </div>
            </div>
        </div>

        <!-- Favorites Suggestion -->
        @if (Model.Favorites is not null && Model.Favorites.Any())
        {
            <div class="suggestion-section" style="max-width: calc(100% - 344px);">
                <h3 class="suggestion-title">
                    <i class="fas fa-heart" style="color:var(--danger); margin-right:8px;"></i>
                    Beğendiklerim
                </h3>
                @await Html.PartialAsync("Suggestion", Model.Favorites)
            </div>
        }
    }
</div>
