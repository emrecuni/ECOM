<nav class="site-header">
    <div class="container">
        <div class="header-top">
            <!-- Logo -->
            <a asp-controller="Main" asp-action="Index" class="header-logo">
                <span class="logo-text">e-com</span>
            </a>

            <!-- Search Bar -->
            <div class="header-search">
                <form asp-controller="Main" asp-action="SearchProductByName" method="get">
                    <div class="search-wrapper">
                        <input type="text" name="search" placeholder="Ürün, kategori veya marka ara...">
                        <button type="submit" class="search-btn">
                            <i class="fas fa-search"></i>
                            <span>Ara</span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Actions -->
            <div class="header-actions">
                <!-- Account Dropdown -->
                <div class="account-dropdown">
                    <div class="account-btn">
                        <div class="icon"><i class="fas fa-user"></i></div>
                        <span>Hesabım</span>
                        <i class="fas fa-chevron-down chevron"></i>
                    </div>
                    <div class="dropdown-menu-custom">
                        <a asp-controller="Account" asp-action="Index">
                            <i class="fas fa-user-circle"></i> Kullanıcı Bilgilerim
                        </a>
                        <a asp-controller="Account" asp-action="Order">
                            <i class="fas fa-box"></i> Siparişlerim
                        </a>
                        <a asp-controller="Account" asp-action="Favorite">
                            <i class="fas fa-heart"></i> Beğendiklerim
                        </a>
                        <a asp-controller="Account" asp-action="Coupon">
                            <i class="fas fa-gift"></i> Kuponlarım
                        </a>
                        <div class="dropdown-divider"></div>
                        <form id="logoutForm" asp-controller="Login" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                        </form>
                        <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();" class="dropdown-logout">
                            <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                        </a>
                    </div>
                </div>

                <!-- Cart Button -->
                <a asp-controller="Cart" asp-action="Index" class="cart-btn">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Sepetim</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Categories Nav -->
    <div class="categories-nav">
        <div class="container">
            <div class="categories-inner">
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Elektronik" class="cat-link">
                    <i class="fas fa-laptop"></i> Elektronik
                </a>
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Moda" class="cat-link">
                    <i class="fas fa-tshirt"></i> Moda
                </a>
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Ev, Yaşam" class="cat-link">
                    <i class="fas fa-home"></i> Ev, Yaşam
                </a>
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Oto, Bahçe" class="cat-link">
                    <i class="fas fa-car"></i> Oto, Bahçe
                </a>
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Anne, Bebek" class="cat-link">
                    <i class="fas fa-baby"></i> Anne, Bebek
                </a>
                <a asp-controller="Main" asp-action="ProductsByCategoryName" asp-route-category="Spor" class="cat-link">
                    <i class="fas fa-running"></i> Spor
                </a>
            </div>
        </div>
    </div>
</nav>
