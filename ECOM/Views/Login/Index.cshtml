@section Styles {
    <link rel="stylesheet" href="~/css/login.css">
}

<div class="auth-page">
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo">
            <a asp-controller="Main" asp-action="Index">
                <span class="auth-logo-text">e-com</span>
            </a>
        </div>

        <h1 class="auth-title">Tekrar hoş geldiniz</h1>
        <p class="auth-subtitle">Hesabınıza giriş yapın</p>

        <form asp-action="Index" method="post">
            <!-- E-Mail -->
            <div class="auth-form-group">
                <label class="auth-label" for="email">E-Posta Adresi</label>
                <div class="auth-input-wrapper">
                    <input type="text" class="auth-input" id="email" name="email"
                           placeholder="ornek@email.com" required>
                    <i class="fas fa-envelope"></i>
                </div>
            </div>

            <!-- Parola -->
            <div class="auth-form-group">
                <label class="auth-label" for="password">Parola</label>
                <div class="auth-input-wrapper">
                    <input type="password" class="auth-input" id="password" name="password"
                           placeholder="Parolanızı girin" required>
                    <i class="fas fa-lock"></i>
                </div>
            </div>

            <!-- Forgot Password -->
            <div class="auth-forgot">
                <a asp-action="ForgotPassword">Şifrenizi mi unuttunuz?</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-submit">
                <i class="fas fa-sign-in-alt"></i> Giriş Yap
            </button>

            <!-- Alerts -->
            @if (ViewBag.WrongPassword is not null)
            {
                <div class="auth-alert auth-alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    @ViewBag.WrongPassword
                </div>
            }
            else if (ViewBag.NullCheck is not null)
            {
                <div class="auth-alert auth-alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    @ViewBag.NullCheck
                </div>
            }

            @{
                if (ViewBag.IsSuccess == StatusTypes.Success)
                {
                    <div class="auth-alert auth-alert-success">
                        <i class="fas fa-check-circle"></i>
                        @ViewBag.Info @TempData["Info"]
                    </div>
                }
                else if (ViewBag.IsSuccess == StatusTypes.Error)
                {
                    <div class="auth-alert auth-alert-error">
                        <i class="fas fa-times-circle"></i>
                        @ViewBag.Info @TempData["Info"]
                    </div>
                }
            }
        </form>

        <div class="auth-footer-link">
            Henüz üye değil misiniz? <a asp-controller="Login" asp-action="Register">Kayıt Olun</a>
        </div>
    </div>
</div>
