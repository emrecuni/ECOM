@model ECOM.DTO.ProductDTO
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="col">
    <div class="product-card">
        <!-- Favorite Button -->
        <a href="#" class="favorite-btn @(Model.IsFavorite ? "favorite-product" : "")" data-id="@Model.ProductId">
            <i class="fas fa-heart @(Model.IsFavorite ? "text-danger" : "")"></i>
        </a>

        <!-- Product Link -->
        <a asp-controller="Product" asp-action="Index" asp-route-id="@Model.ProductId" class="product">
            <!-- Image -->
            <div class="product-img-wrapper">
                <img src="~/@Model.ImagePath" alt="@Model.Name">
            </div>

            <!-- Card Body -->
            <div class="card-body">
                <div class="product-name">@Model.Name</div>

                <div class="star-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="star" data-filled="@(i <= Model.Score ? "true" : "false")">&#9733;</span>
                    }
                </div>

                <div class="price">₺@Model.Price</div>
            </div>
        </a>
    </div>
</div>
