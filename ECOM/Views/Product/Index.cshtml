@model ECOM.Models.ProductDetailViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/product.css">
}

<div class="container product-page">
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <a asp-controller="Main" asp-action="Index">Ana Sayfa</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <a asp-controller="Main" asp-action="ProductsByCategoryId" asp-route-id="@Model.Product.SupCategoryId">@Model.Product!.SupCategory.Name</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <a asp-controller="Main" asp-action="ProductsByCategoryId" asp-route-id="@Model.Product.SubCategoryId">@Model.Product.SubCategory.Name</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <span class="current">@Model.Product.Name</span>
    </div>

    <!-- Main Product Card -->
    <div class="product-main-card">
        <!-- Image -->
        <div class="product-gallery">
            <div class="product-main-img">
                <img src="~/@Model.Product.ImagePath" alt="@Model.Product.Name">
            </div>
        </div>

        <!-- Info -->
        <div class="product-info-panel">
            <span class="product-brand-badge">
                <i class="fas fa-tag"></i>
                @Model.Product.Brand.Name
            </span>

            <h1 class="product-title">@Model.Product.Name</h1>

            <!-- Rating -->
            <div class="product-rating-row">
                @if (Model.Product.Comments.Count > 0)
                {
                    <div class="score-badge">
                        <i class="fas fa-star"></i>
                        @Model.Product.Score
                    </div>
                    <div class="star-row">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star" data-filled="@(i <= Model.Product.Score ? "true" : "false")">&#9733;</span>
                        }
                    </div>
                    <a class="review-count-link" href="javascript:void(0);" onclick="scrollToSection('comments')">
                        @Model.Product.Comments.Count Değerlendirme
                    </a>
                }
                else
                {
                    <span style="font-size:13px; color:var(--text-muted);">
                        <i class="far fa-star"></i> Henüz değerlendirilmemiş
                    </span>
                    <a class="review-count-link" href="javascript:void(0);" onclick="scrollToSection('leave-review')">
                        İlk sen değerlendir →
                    </a>
                }
            </div>

            <!-- Seller -->
            <div class="seller-info">
                <i class="fas fa-store" style="color:var(--primary)"></i>
                <span>Satıcı:</span>
                <span class="seller-badge">@Model.Product.Seller.Name</span>
            </div>

            <!-- Price -->
            <div class="product-price-block">
                <span class="price-currency">₺</span>
                <span class="price-amount">@Model.Product.Price</span>
            </div>

            <!-- Actions -->
            <div class="product-actions">
                <form asp-action="AddCart" method="post" style="flex:1; min-width:160px;">
                    <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                    <input type="hidden" name="productName" value="@Model.Product.Name">
                    <input type="hidden" name="sellerId" value="@Model.Product.SellerId">
                    <input type="hidden" name="price" value="@Model.Product.Price">
                    <button type="submit" class="btn-add-cart" style="width:100%;">
                        <i class="fas fa-shopping-cart"></i>
                        Sepete Ekle
                    </button>
                </form>
            </div>

            <!-- Trust Badges -->
            <div style="display:flex; gap:16px; flex-wrap:wrap; padding-top:4px;">
                <div style="display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--text-muted);">
                    <i class="fas fa-shield-alt" style="color:var(--success);"></i> Güvenli Ödeme
                </div>
                <div style="display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--text-muted);">
                    <i class="fas fa-truck" style="color:var(--primary);"></i> Ücretsiz Kargo
                </div>
                <div style="display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--text-muted);">
                    <i class="fas fa-undo" style="color:var(--warning);"></i> Kolay İade
                </div>
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="product-section-card">
        <h2 class="section-card-title">
            <i class="fas fa-align-left"></i> Ürün Açıklaması
        </h2>
        <p class="description-text">@Model.Product.Description</p>
    </div>

    <!-- Reviews -->
    <div id="comments" class="product-section-card">
        <h2 class="section-card-title">
            <i class="fas fa-comments"></i>
            Yorumlar
            <span style="font-size:14px; font-weight:500; color:var(--text-muted); margin-left:4px;">(@Model.Comments.Count yorum)</span>
        </h2>

        @if (Model.Comments.Count == 0)
        {
            <div class="no-reviews">
                <i class="far fa-comment-dots"></i>
                Bu ürün henüz yorum almamış. İlk yorumu siz yapın!
            </div>
        }
        else
        {
            @foreach (var comment in Model.Comments)
            {
                <div class="review-item">
                    <div class="reviewer-info">
                        <div class="reviewer-avatar">
                            @comment.Customer.Name.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div class="reviewer-name">@comment.Customer.Name @comment.Customer.Surname!.Substring(0, 1).</div>
                            <div class="review-stars">
                                @for (int i = 0; i < 5; i++)
                                {
                                    @(i < comment.Score ? "★" : "☆")
                                }
                            </div>
                        </div>
                    </div>
                    <p class="review-text">@comment.Comment</p>
                </div>
            }
        }
    </div>

    <!-- Leave Review -->
    <div id="leave-review" class="product-section-card">
        <h2 class="section-card-title">
            <i class="fas fa-pen"></i> Yorum Yapın
        </h2>
        <div class="write-review-form">
            <form asp-controller="Product" asp-action="SendComment" method="post">
                <label style="font-size:13.5px; font-weight:600; color:var(--text-secondary); display:block; margin-bottom:10px;">Puanınızı Seçin:</label>
                <ul class="rating-stars-select" id="rating">
                    @for (int i = 5; i > 0; i--)
                    {
                        <li data-value="@i">&#9733;</li>
                    }
                </ul>

                <input type="hidden" id="rate" name="rate" value="3">
                <input type="hidden" name="id" value="@Model.Product.ProductId">

                <textarea class="review-textarea" id="review-text" name="review" rows="4"
                          placeholder="Ürün hakkındaki düşüncelerinizi paylaşın..."></textarea>

                <button class="btn-send-review" type="submit">
                    <i class="fas fa-paper-plane"></i> Yorumu Gönder
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function scrollToSection(id) {
        const element = document.getElementById(id);
        if (element) {
            element.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    const stars = document.querySelectorAll('#rating li');
    const rateInputValue = document.getElementById('rate');

    stars.forEach((star, index) => {
        star.addEventListener('mouseover', function () {
            stars.forEach(s => s.style.color = '');
            for (let i = stars.length - 1; i >= index; i--) {
                stars[i].style.color = '#F6A623';
            }
        });

        star.addEventListener('mouseout', function () {
            updateStarDisplay();
        });

        star.addEventListener('click', function () {
            stars.forEach(s => s.classList.remove('selected'));
            const val = parseInt(star.getAttribute('data-value'));
            rateInputValue.value = val;
            stars.forEach(s => {
                const sv = parseInt(s.getAttribute('data-value'));
                if (sv >= val) s.classList.add('selected');
            });
        });
    });

    function updateStarDisplay() {
        const selected = rateInputValue.value;
        stars.forEach(s => {
            const sv = parseInt(s.getAttribute('data-value'));
            s.style.color = s.classList.contains('selected') ? '#F6A623' : '';
        });
    }
</script>

@if (TempData["Info"] is not null)
{
    <script>
        alert('@Html.Raw(TempData["Info"])');
    </script>
}
