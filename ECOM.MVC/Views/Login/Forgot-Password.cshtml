@using ECOM.Models

@section Styles {
    <link rel="stylesheet" href="~/css/login.css">
}

<div class="auth-page">
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo">
            <a asp-controller="Main" asp-action="Index">
                <span class="auth-logo-text">e-com</span>
            </a>
        </div>

        <!-- Icon -->
        <div style="display:flex; justify-content:center; margin-bottom:20px;">
            <div style="width:64px; height:64px; background:var(--primary-bg); border-radius:50%; display:flex; align-items:center; justify-content:center;">
                <i class="fas fa-key" style="font-size:26px; color:var(--primary);"></i>
            </div>
        </div>

        <h1 class="auth-title">Parolanızı mı unuttunuz?</h1>
        <p class="auth-subtitle">E-posta adresinizi girin, yenileme bağlantısını hemen gönderelim.</p>

        <form action="ForgotPassword" method="post">
            <div class="auth-form-group">
                <label class="auth-label" for="email">E-Posta Adresi</label>
                <div class="auth-input-wrapper">
                    <input type="email" class="auth-input" id="email" name="email"
                           placeholder="ornek@email.com" required>
                    <i class="fas fa-envelope"></i>
                </div>
            </div>

            <button type="submit" class="auth-submit">
                <i class="fas fa-paper-plane"></i> Bağlantı Gönder
            </button>

            @if (ViewBag.IsSuccess is not null)
            {
                string alertClass = ViewBag.IsSuccess switch
                {
                    StatusTypes.Success => "auth-alert-success",
                    StatusTypes.Warning => "auth-alert-warning",
                    StatusTypes.Error => "auth-alert-error",
                    _ => "auth-alert-warning",
                };

                string iconClass = ViewBag.IsSuccess switch
                {
                    StatusTypes.Success => "fas fa-check-circle",
                    StatusTypes.Warning => "fas fa-exclamation-triangle",
                    StatusTypes.Error => "fas fa-times-circle",
                    _ => "fas fa-info-circle",
                };

                <div class="auth-alert @alertClass">
                    <i class="@iconClass"></i>
                    @ViewBag.Info
                </div>
            }
        </form>

        <div class="auth-footer-link">
            <a asp-action="Index">
                <i class="fas fa-arrow-left" style="font-size:11px;"></i> Giriş sayfasına dön
            </a>
        </div>
    </div>
</div>
