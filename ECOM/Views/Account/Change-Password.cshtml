<div class="membership-form">
    <form method="post" action="ChangePassword">

        <div class="form-field-group">
            <label class="field-label">Mevcut Parola</label>
            <div class="field-input-wrapper">
                <input type="password" class="field-input" id="password" name="password"
                       placeholder="Mevcut parolanızı girin" required>
                <i class="fas fa-lock"></i>
            </div>
        </div>

        <div class="form-field-group">
            <label class="field-label">Yeni Parola</label>
            <div class="field-input-wrapper">
                <input type="password" class="field-input" id="newPassword" name="newPassword"
                       placeholder="En az 8 karakter" required>
                <i class="fas fa-lock"></i>
            </div>
        </div>

        <div class="form-field-group">
            <label class="field-label">Yeni Parola (Tekrar)</label>
            <div class="field-input-wrapper">
                <input type="password" class="field-input" id="againPassword" name="againPassword"
                       placeholder="Yeni parolanızı tekrar girin" required>
                <i class="fas fa-lock"></i>
            </div>
        </div>

        <div style="background:var(--gray-100); border-radius:var(--radius-md); padding:12px 16px; margin-bottom:20px; display:flex; align-items:flex-start; gap:10px;">
            <i class="fas fa-shield-alt" style="color:var(--primary); margin-top:2px; flex-shrink:0;"></i>
            <p style="font-size:13px; color:var(--text-muted); margin:0; line-height:1.5;">
                Güvenliğiniz için adınız, soyadınız ve doğum tarihinizi içermeyen bir parola belirleyin.
            </p>
        </div>

        <button type="submit" class="account-save-btn">
            <i class="fas fa-key"></i> Parolayı Güncelle
        </button>
    </form>
</div>
