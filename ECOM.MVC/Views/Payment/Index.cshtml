@model ECOM.Models.AddressViewModel

@section Styles {
    <link href="~/css/payment.css" rel="stylesheet" />
    <link href="~/css/payment-header.css" rel="stylesheet" />
    <link href="~/css/cart.css" rel="stylesheet" />
}

@await Html.PartialAsync("Payment-Header")

<div class="container payment-page">

    <!-- Steps -->
    <div class="payment-steps">
        <div class="payment-step completed">
            <span class="payment-step-num"><i class="fas fa-check"></i></span>
            <span>Sepetim</span>
        </div>
        <div class="payment-step-line completed"></div>
        <div class="payment-step active">
            <span class="payment-step-num">2</span>
            <span>Teslimat Adresi</span>
        </div>
        <div class="payment-step-line"></div>
        <div class="payment-step">
            <span class="payment-step-num">3</span>
            <span>Ödeme</span>
        </div>
    </div>

    <div class="payment-layout">

        <!-- ===== LEFT: ADDRESS ===== -->
        <div class="payment-left">

            <!-- Selected Address Display -->
            @if (Model.Addresses.Count > 0)
            {
                <div class="payment-section-card" id="selected-address-card">
                    <div class="payment-section-header">
                        <i class="fas fa-map-marker-alt"></i>
                        <h3>Teslimat Adresi</h3>
                    </div>
                    <div class="selected-address-box" id="selected-address-content">
                        <div class="address-tag">
                            <i class="fas fa-home"></i>
                            @Model.Addresses.ToList()[0].AddressName
                        </div>
                        <p class="address-detail">
                            @Model.Addresses.ToList()[0].Address
                            <span class="address-location">
                                @Model.Addresses.ToList()[0].Neighbourhood.Name /
                                @Model.Addresses.ToList()[0].District.Name /
                                @Model.Addresses.ToList()[0].City.Name
                            </span>
                        </p>
                    </div>
                    <button onclick="showAddresses()" class="address-change-btn">
                        <i class="fas fa-exchange-alt"></i> Adres Ekle / Değiştir
                    </button>
                </div>
            }

            <!-- Address Panel -->
            <div id="addresses" class="payment-section-card" style="display:none;">
                <div class="payment-section-header">
                    <i class="fas fa-map-marked-alt"></i>
                    <h3>Adreslerim</h3>
                    <button onclick="addAddress()" class="add-new-address-btn" style="margin-left:auto;">
                        <i class="fas fa-plus"></i> Yeni Adres
                    </button>
                </div>

                <!-- Existing Addresses -->
                <div id="other-addresses" class="address-list">
                    @if (Model.Addresses.Count > 0)
                    {
                        @foreach (var address in Model.Addresses.ToList())
                        {
                            <div class="address-option" onclick="selectAddress(this)"
                                 data-address-id="@address.AddressId">
                                <div class="address-option-radio">
                                    <span class="radio-dot"></span>
                                </div>
                                <div class="address-option-info">
                                    <div class="address-option-name">
                                        <i class="fas fa-home"></i> @address.AddressName
                                    </div>
                                    <div class="address-option-detail">
                                        @address.Address —
                                        @address.Neighbourhood.Name / @address.District.Name / @address.City.Name
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- New Address Form -->
                <div id="new-address" style="display:none;">
                    <div class="new-address-divider">
                        <span>Yeni Adres Ekle</span>
                    </div>
                    <form asp-controller="Account" asp-action="Address" method="post" class="new-address-form">

                        <div class="form-section-title">Kişisel Bilgiler</div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
                            <div class="form-field-group">
                                <label class="field-label">Ad</label>
                                <div class="field-input-wrapper">
                                    <input type="text" name="name" class="field-input" placeholder="Adınız">
                                    <i class="fas fa-user"></i>
                                </div>
                            </div>
                            <div class="form-field-group">
                                <label class="field-label">Soyad</label>
                                <div class="field-input-wrapper">
                                    <input type="text" name="surname" class="field-input" placeholder="Soyadınız">
                                    <i class="fas fa-user"></i>
                                </div>
                            </div>
                        </div>
                        <div class="form-field-group">
                            <label class="field-label">Telefon</label>
                            <div class="field-input-wrapper">
                                <input type="tel" name="phone" class="field-input" placeholder="05XX XXX XX XX">
                                <i class="fas fa-phone"></i>
                            </div>
                        </div>

                        <div class="form-section-title" style="margin-top:20px;">Adres Bilgileri</div>
                        <div class="form-field-group">
                            <label class="field-label">Adres Adı</label>
                            <div class="field-input-wrapper">
                                <input type="text" name="addressName" class="field-input" placeholder="Ev, İş...">
                                <i class="fas fa-tag"></i>
                            </div>
                        </div>
                        <div class="form-field-group">
                            <label class="field-label">Açık Adres</label>
                            <textarea name="address" class="field-input" rows="3"
                                      placeholder="Cadde, sokak, bina no, daire no..."
                                      style="height:auto; resize:vertical;"></textarea>
                        </div>

                        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
                            <div class="form-field-group">
                                <label class="field-label">Şehir</label>
                                <select class="field-input" id="cityId" name="cityId" style="cursor:pointer;">
                                    <option selected disabled>Seçiniz</option>
                                    @foreach (var city in Model.Cities.ToList())
                                    {
                                        <option value="@city.CityId">@city.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-field-group">
                                <label class="field-label">İlçe</label>
                                <select class="field-input" id="districtId" name="districtId" style="cursor:pointer;">
                                    <option selected disabled>Seçiniz</option>
                                    @if (Model.Districts.Count > 0)
                                    {
                                        @foreach (var district in Model.Districts.ToList())
                                        {
                                            <option value="@district.DistrictId">@district.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-field-group">
                                <label class="field-label">Mahalle</label>
                                <select class="field-input" id="neighbourhoodId" name="neighbourhoodId" style="cursor:pointer;">
                                    <option selected disabled>Seçiniz</option>
                                    @if (Model.Neighbourhoods.Count > 0)
                                    {
                                        @foreach (var neighbourhood in Model.Neighbourhoods.ToList())
                                        {
                                            <option value="@neighbourhood.NeighbourhoodId">@neighbourhood.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="account-save-btn" style="width:100%; justify-content:center; margin-top:8px;">
                            <i class="fas fa-plus"></i> Adresi Kaydet
                        </button>
                    </form>
                </div>
            </div>

        </div>

        <!-- ===== RIGHT: SUMMARY ===== -->
        <div class="payment-right">
            <div class="payment-summary">
                <div class="payment-section-header" style="margin-bottom:20px;">
                    <i class="fas fa-receipt"></i>
                    <h3>Sipariş Özeti</h3>
                </div>

                @{
                    decimal cartSummaryPrice = 0;
                    int productCount = 0;
                    foreach (var cart in Model.Cart.ToList())
                    {
                        if (cart.Enable == true)
                        {
                            cartSummaryPrice += cart.TotalPrice;
                            productCount++;
                        }
                    }
                }

                <div class="summary-row">
                    <span>Ürünler (@productCount adet)</span>
                    <span>₺@cartSummaryPrice.ToString("F2")</span>
                </div>
                <div class="summary-row">
                    <span>Kargo</span>
                    <span class="free-cargo"><i class="fas fa-check"></i> Bedava</span>
                </div>
                <div class="summary-row total-row">
                    <span>Toplam</span>
                    <span class="total-amount">₺@cartSummaryPrice.ToString("F2")</span>
                </div>

                <form asp-controller="Payment" asp-action="Pay" method="post">
                    <input type="hidden" name="addressId" id="addressId" />
                    <button type="submit" class="pay-btn" onclick="prepareAddressId()">
                        <i class="fas fa-lock"></i> Siparişi Onayla
                    </button>
                </form>

                <div class="secure-note">
                    <i class="fas fa-shield-alt"></i>
                    256-bit SSL ile güvenli ödeme
                </div>

                <!-- Cart Items Preview -->
                <div class="cart-preview">
                    @foreach (var cart in Model.Cart.ToList().Where(c => c.Enable == true))
                    {
                        <div class="cart-preview-item">
                            <div class="cart-preview-info">
                                <span class="cart-preview-name">@cart.Product.Name</span>
                                <span class="cart-preview-qty">x@cart.Count</span>
                            </div>
                            <span class="cart-preview-price">₺@cart.TotalPrice.ToString("F2")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function showAddresses() {
        const panel = document.getElementById('addresses');
        panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
    }

    function addAddress() {
        const others = document.getElementById('other-addresses');
        const newAddr = document.getElementById('new-address');
        others.style.display = others.style.display === 'none' ? 'block' : 'none';
        newAddr.style.display = newAddr.style.display === 'none' ? 'block' : 'none';
    }

    function selectAddress(element) {
        document.querySelectorAll('.address-option').forEach(a => a.classList.remove('selected'));
        element.classList.add('selected');

        const content = document.getElementById('selected-address-content');
        const name = element.querySelector('.address-option-name').textContent.trim();
        const detail = element.querySelector('.address-option-detail').textContent.trim();

        content.innerHTML = `
            <div class="address-tag"><i class="fas fa-home"></i> ${name}</div>
            <p class="address-detail">${detail}</p>
        `;
        showAddresses();
    }

    function prepareAddressId() {
        const selected = document.querySelector('.address-option.selected');
        const address = selected ? selected.dataset.addressId : @Model.Addresses[0].AddressId;
        document.getElementById('addressId').value = address;
    }

    $(document).ready(function () {
        $('#cityId').change(function () {
            const cityId = $(this).val();
            $('#districtId').empty().append('<option selected disabled>Yükleniyor...</option>');
            $('#neighbourhoodId').empty().append('<option selected disabled>Seçiniz</option>');
            $.getJSON('/Payment/GetDistricts', { cityId }, function (data) {
                $('#districtId').empty().append('<option selected disabled>Seçiniz</option>');
                $.each(data, function (i, d) {
                    $('#districtId').append(`<option value="${d.districtId}">${d.name}</option>`);
                });
            });
        });

        $('#districtId').change(function () {
            const districtId = $(this).val();
            $('#neighbourhoodId').empty().append('<option selected disabled>Yükleniyor...</option>');
            $.getJSON('/Payment/GetNeighbourhoods', { districtId }, function (data) {
                $('#neighbourhoodId').empty().append('<option selected disabled>Seçiniz</option>');
                $.each(data, function (i, n) {
                    $('#neighbourhoodId').append(`<option value="${n.neighbourhoodId}">${n.name}</option>`);
                });
            });
        });
    });
</script>
