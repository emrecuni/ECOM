@model ECOM.MVC.OldFiles.Data.Customers

<div class="membership-form">
    <form method="post" asp-action="EditMembership" asp-controller="Account">

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-field-group">
                <label class="field-label">Ad</label>
                <div class="field-input-wrapper">
                    <input type="text" class="field-input" name="name" placeholder="Adınız" value="@Model.Name" required>
                    <i class="fas fa-user"></i>
                </div>
            </div>
            <div class="form-field-group">
                <label class="field-label">Soyad</label>
                <div class="field-input-wrapper">
                    <input type="text" class="field-input" name="surname" placeholder="Soyadınız" value="@Model.Surname" required>
                    <i class="fas fa-user"></i>
                </div>
            </div>
        </div>

        <div class="form-field-group">
            <label class="field-label">Doğum Tarihi</label>
            <div class="field-input-wrapper">
                @{
                    string birthDate = null!;
                    if (Model.BirthDate is not null)
                        birthDate = Model.BirthDate.Value.ToString("yyyy-MM-dd");
                }
                <input type="date" class="field-input" name="birthdate" value="@birthDate" required>
                <i class="fas fa-calendar"></i>
            </div>
        </div>

        <div class="form-field-group">
            <label class="field-label">Cinsiyet</label>
            <div style="display:flex; gap:16px; margin-top:6px;">
                <label class="radio-option @(Model.Gender == true ? "selected" : "")">
                    <input type="radio" name="gender" value="true" @(Model.Gender == true ? "checked" : "")>
                    <i class="fas fa-mars"></i> Erkek
                </label>
                <label class="radio-option @(Model.Gender == false ? "selected" : "")">
                    <input type="radio" name="gender" value="false" @(Model.Gender == false ? "checked" : "")>
                    <i class="fas fa-venus"></i> Kadın
                </label>
            </div>
        </div>

        <input type="hidden" name="customerId" value="@Model.CustomerId" />

        <button class="account-save-btn" type="submit">
            <i class="fas fa-check"></i> Değişiklikleri Kaydet
        </button>
    </form>
</div>
