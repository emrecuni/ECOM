@{
    ViewData["Title"] = "Ödeme";
}

@section Styles {
    <link href="~/css/payment.css" rel="stylesheet" />
    <link href="~/css/payment-header.css" rel="stylesheet" />
}

@await Html.PartialAsync("Payment-Header")

<div class="container" style="padding: 32px 16px; max-width: 680px;">
    <div class="payment-section-card">
        <div class="payment-section-header" style="margin-bottom:24px;">
            <i class="fas fa-credit-card"></i>
            <h3>Ödeme Formu</h3>
        </div>

        <div class="iyzipay-form-wrapper">
            @Html.Raw(ViewBag.CheckoutFormContent)
        </div>
    </div>
</div>
