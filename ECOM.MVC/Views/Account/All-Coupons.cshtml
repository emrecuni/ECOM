@* All-Coupons.cshtml *@
<div class="coupons-grid">
    <!-- Active Coupon -->
    <div class="modern-coupon-card active-coupon">
        <div class="coupon-left">
            <div class="coupon-amount"><b>50</b> <span>TL</span></div>
            <div class="coupon-type">İndirim Kuponu</div>
        </div>
        <div class="coupon-divider">
            <div class="coupon-circle top"></div>
            <div class="coupon-dashes"></div>
            <div class="coupon-circle bottom"></div>
        </div>
        <div class="coupon-right">
            <div class="coupon-status valid"><i class="fas fa-check-circle"></i> Aktif</div>
            <div class="coupon-detail">Alt limit: 100 TL</div>
            <div class="coupon-expiry"><i class="fas fa-calendar-alt"></i> 11.12.2025'e kadar geçerli</div>
            <div class="coupon-desc">100 TL ve üzeri alışverişlerde geçerlidir.</div>
        </div>
    </div>

    <!-- Expired Coupon -->
    <div class="modern-coupon-card expired-coupon">
        <div class="coupon-left">
            <div class="coupon-amount"><b>25</b> <span>TL</span></div>
            <div class="coupon-type">İndirim Kuponu</div>
        </div>
        <div class="coupon-divider">
            <div class="coupon-circle top"></div>
            <div class="coupon-dashes"></div>
            <div class="coupon-circle bottom"></div>
        </div>
        <div class="coupon-right">
            <div class="coupon-status expired"><i class="fas fa-times-circle"></i> Süresi Doldu</div>
            <div class="coupon-detail">Alt limit: 0 TL</div>
            <div class="coupon-expiry"><i class="fas fa-calendar-alt"></i> 19.07.2021'de sona erdi</div>
            <div class="coupon-desc">Hediye çekiniz.</div>
        </div>
    </div>

    <!-- Used Coupon -->
    <div class="modern-coupon-card used-coupon">
        <div class="coupon-left">
            <div class="coupon-amount"><b>20</b> <span>TL</span></div>
            <div class="coupon-type">İndirim Kuponu</div>
        </div>
        <div class="coupon-divider">
            <div class="coupon-circle top"></div>
            <div class="coupon-dashes"></div>
            <div class="coupon-circle bottom"></div>
        </div>
        <div class="coupon-right">
            <div class="coupon-status used"><i class="fas fa-check"></i> Kullanıldı</div>
            <div class="coupon-detail">Alt limit: 100 TL</div>
            <div class="coupon-expiry"><i class="fas fa-calendar-check"></i> 11.12.2024'te kullanıldı</div>
            <div class="coupon-desc">100 TL ve üzeri alışverişlerde geçerlidir.</div>
        </div>
    </div>
</div>
