@section Styles {
    <link rel="stylesheet" href="~/css/login.css">
}

<div class="auth-page">
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo">
            <a asp-controller="Main" asp-action="Index">
                <span class="auth-logo-text">e-com</span>
            </a>
        </div>

        <h1 class="auth-title">Hesap Oluşturun</h1>
        <p class="auth-subtitle">Binlerce ürüne hemen erişin</p>

        <form asp-action="Register" method="post">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="auth-form-group">
                    <label class="auth-label">Ad</label>
                    <div class="auth-input-wrapper">
                        <input type="text" class="auth-input" name="name" placeholder="Adınız" required>
                        <i class="fas fa-user"></i>
                    </div>
                </div>
                <div class="auth-form-group">
                    <label class="auth-label">Soyad</label>
                    <div class="auth-input-wrapper">
                        <input type="text" class="auth-input" name="surname" placeholder="Soyadınız" required>
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>

            <div class="auth-form-group">
                <label class="auth-label">E-Posta Adresi</label>
                <div class="auth-input-wrapper">
                    <input type="email" class="auth-input" name="email" placeholder="ornek@email.com" required>
                    <i class="fas fa-envelope"></i>
                </div>
            </div>

            <div class="auth-form-group">
                <label class="auth-label">Parola</label>
                <div class="auth-input-wrapper">
                    <input type="password" class="auth-input" name="password" placeholder="En az 8 karakter" required>
                    <i class="fas fa-lock"></i>
                </div>
            </div>

            <div class="auth-form-group">
                <label class="auth-label">Parola Tekrar</label>
                <div class="auth-input-wrapper">
                    <input type="password" class="auth-input" name="passwordConfirm" placeholder="Parolanızı tekrar girin" required>
                    <i class="fas fa-lock"></i>
                </div>
            </div>

            <button type="submit" class="auth-submit">
                <i class="fas fa-user-plus"></i> Kayıt Ol
            </button>

            @if (ViewBag.Error is not null)
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fas fa-times-circle"></i>
                    @ViewBag.Error
                </div>
            }
        </form>

        <div class="auth-footer-link">
            Zaten hesabınız var mı? <a asp-action="Index">Giriş Yapın</a>
        </div>
    </div>
</div>
